# =============================================================================
# SealPi-Blog 后端基础设施环境变量模板
# 复制为 .env.backend.local 并填写真实值。所有 change-me-* 均为必填。
# 此文件由 docker-compose.yml 和 start-local-test.ps1 读取。
# =============================================================================

# MySQL
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_DATABASE=sealpi_blog

# MinIO 对象存储
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password

# MinIO 对外公开访问地址（浏览器可直接访问的 URL）
# 本地开发: http://localhost:13308
# 生产环境: 填写真实域名或 IP，例如 https://minio.example.com
# 此值同步写入数据库中的文件 URL，必须与实际访问地址一致
MINIO_PUBLIC_BASE_URL=http://localhost:13308

# Flyway schema migration
# 仅在 迁移现有（已有表但无迁移历史）的数据库 时需要设置。
# 全新安装（空 MySQL volume）请留空，Flyway 会自动从 V0 开始执行所有迁移。
# 现有部署升级（数据库已存在但无 flyway_schema_history 表）时：
#   SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
#   SPRING_FLYWAY_BASELINE_VERSION=2   # 或已应用到的最高版本号
# SPRING_FLYWAY_BASELINE_ON_MIGRATE=
# SPRING_FLYWAY_BASELINE_VERSION=

# Admin JWT（前后端共享，必须一致）
# 生成命令: openssl rand -base64 32
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
ADMIN_JWT_GITHUBUSERIDCLAIM=githubUserId
# Next.js BFF 向后端发送 HS256 JWT，必须设为 true 才能正常鉴权。
# 设为 false 时后端将拒绝所有 JWT token，仅接受 GitHub OAuth token（原始 access_token）。
ADMIN_AUTH_ALLOW_LEGACY_JWT=true

# 管理员 GitHub userId 白名单（逗号分隔的数字 ID）
# 获取自己的 ID: curl https://api.github.com/users/<your-github-login>
ADMIN_GITHUB_USERIDS=change-me-github-user-id

# 内部同步密钥（Next.js → Java 用户同步，前后端共享）
# 生成命令: openssl rand -base64 32
BLOG_INTERNAL_SYNC_SECRET=change-me-internal-sync-secret

# GitHub OAuth App（Next.js 前端使用，放在此处统一管理）
# 在 GitHub Settings > Developer settings > OAuth Apps 创建
# Authorization callback URL: http://localhost:13311/api/auth/callback/github
GITHUB_ID=change-me-github-oauth-client-id
GITHUB_SECRET=change-me-github-oauth-client-secret

# NextAuth 加密密钥（Next.js 使用）
# 生成命令: openssl rand -base64 32
AUTH_SECRET=change-me-nextauth-secret

# =============================================================================
# 前端容器配置（docker-compose frontend service 使用）
# =============================================================================

# NextAuth 回调基础 URL（浏览器可访问的前端地址）
# 本地 docker-compose 部署: http://localhost:13311
# 必须与 GitHub OAuth App 中配置的 Authorization callback URL 前缀一致
AUTH_URL=http://localhost:13311

# MinIO 主机名（Next.js Image 优化白名单 + 运行时标识）
# 本地: localhost，生产: 填写 MinIO 真实主机名
MINIO_PUBLIC_HOSTNAME=localhost

# 前端浏览器侧访问后端的公开 URL（烘焙进 JS bundle，见 Dockerfile build args）
# 本地 docker-compose: http://localhost:13310
# 生产: 填写后端公开 URL，如 https://api.sealpi.cn
NEXT_PUBLIC_BLOG_API_BASE_URL=http://localhost:13310
