# =============================================================================
# SealPi-Blog 前端环境变量模板
# 复制为 .env.local 并填写真实值。所有 change-me-* 均为必填。
# =============================================================================

# -----------------------------------------------------------------------------
# 博客后端 API 地址
# BLOG_API_BASE_URL: 服务端（SSR/BFF）调用，优先级高于 NEXT_PUBLIC_
# NEXT_PUBLIC_BLOG_API_BASE_URL: 浏览器端调用（如无服务端变量则用此值）
# 生产建议只设 BLOG_API_BASE_URL（内网地址），不对外暴露 NEXT_PUBLIC_
# -----------------------------------------------------------------------------
BLOG_API_BASE_URL=http://localhost:13310
NEXT_PUBLIC_BLOG_API_BASE_URL=http://localhost:13310

# -----------------------------------------------------------------------------
# GitHub OAuth App（在 GitHub Settings > Developer settings > OAuth Apps 创建）
# Authorization callback URL: https://<your-domain>/api/auth/callback/github
# -----------------------------------------------------------------------------
GITHUB_ID=change-me-github-oauth-client-id
GITHUB_SECRET=change-me-github-oauth-client-secret

# -----------------------------------------------------------------------------
# NextAuth / Auth.js
# AUTH_SECRET: 随机字符串，用于加密 JWT session（生产必须设置）
#   生成命令: openssl rand -base64 32
# AUTH_URL: 生产部署时必须设置为前端的完整 URL（含 https://）
#   例如: AUTH_URL=https://blog.example.com
# -----------------------------------------------------------------------------
AUTH_SECRET=change-me-nextauth-secret
AUTH_URL=https://your-domain.example.com

# -----------------------------------------------------------------------------
# 管理员白名单（与后端共享）
# ADMIN_GITHUB_USERIDS: 逗号分隔的 GitHub userId（数字 ID，非用户名）
#   获取自己的 ID: curl https://api.github.com/users/<your-github-login>
# ADMIN_JWT_SECRET: BFF 签发管理 JWT 的 HS256 密钥，必须与后端 .env.backend.local 一致
#   生成命令: openssl rand -base64 32
# ADMIN_JWT_GITHUBUSERIDCLAIM: JWT claim 名称，保持默认即可
# -----------------------------------------------------------------------------
ADMIN_GITHUB_USERIDS=change-me-github-user-id
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
ADMIN_JWT_GITHUBUSERIDCLAIM=githubUserId

# -----------------------------------------------------------------------------
# 内部服务同步密钥（与后端共享）
# 用于 Next.js 登录时向 Java 后端同步 GitHub 用户信息
# 必须与后端 .env.backend.local 中的 BLOG_INTERNAL_SYNC_SECRET 一致
# -----------------------------------------------------------------------------
BLOG_INTERNAL_SYNC_SECRET=change-me-internal-sync-secret

# -----------------------------------------------------------------------------
# Giscus 评论系统（可选，未配置则评论区不显示）
# 访问 https://giscus.app 按步骤获取以下值
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# -----------------------------------------------------------------------------
# MinIO 图片域名（用于 Next.js Image 优化白名单）
# 填写 MinIO 对外暴露的主机名（不含协议前缀）
# 例如: MINIO_PUBLIC_HOSTNAME=minio.example.com 或 192.168.1.100
# 与后端 ADMIN_UPLOAD_PUBLICBASEURL 保持一致
# -----------------------------------------------------------------------------
MINIO_PUBLIC_HOSTNAME=localhost
